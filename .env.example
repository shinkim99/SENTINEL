# .env.example — 커밋 O. 실제 값은 .env(gitignore)에 설정.

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_SCREEN=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_IMPACT=claude-sonnet-4-6

# 한국 법령 API (법제처 Open API — 신청 후 발급)
LAW_GO_KR_API_KEY=

# 발송 수신자 (쉼표 구분). draft 모드는 첫 주소(운영자 본인)에게만, send 모드는 전체.
DIGEST_RECIPIENTS=

# 회신 수신 주소 (Reply-To). 주석 처리 시 기본값(운영자 본인 메일) 사용.
# DIGEST_REPLY_TO=

# ── Resend API (서버리스/GitHub Actions 발송 경로) ──
# https://resend.com 에서 발급. SMTP 없이 HTTPS 발송.
RESEND_API_KEY=
# 발송 From — 인증된 자체 도메인 주소. 주석 처리 시 기본값 사용.
# RESEND_FROM_EMAIL=

# SMTP 설정 (로컬 테스트 전용 — 운영은 Resend/n8n)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# 발송 모드: review_first | auto_send
SEND_MODE=review_first

# 대시보드 URL (이메일 CTA 버튼 링크)
# 로컬 개발(FastAPI): http://localhost:8010/dashboard
# 서버리스(GitHub Pages): https://shinkim99.github.io/SENTINEL/
DASHBOARD_URL=http://localhost:8010/dashboard

# 데이터 경로 (기본값 사용 가능, 변경 시만 설정)
# SOURCES_PATH=data/sources.json
# PROFILES_DIR=data/profiles
# STATE_DIR=data/state

# 회사망 SSL inspection 대비: httpx verify= 에 그대로 전달.
# true(기본) | false(검증 생략) | CA 번들 경로
# HTTP_VERIFY=C:\path\to\ca-bundle.crt
# (레거시: REQUESTS_CA_BUNDLE / SSL_CERT_FILE 도 HTTP_VERIFY 미지정 시 폴백으로 동작)
# REQUESTS_CA_BUNDLE=C:\path\to\ca-bundle.crt
