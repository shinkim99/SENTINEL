# .env.example — 커밋 O. 실제 값은 .env(gitignore)에 설정.

# 발송 수신자 (쉼표 구분)
DIGEST_RECIPIENTS=

# SMTP 설정
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# AI 모델 설정
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_PRIMARY=claude-sonnet-4-6
ANTHROPIC_MODEL_SCREEN1=claude-haiku-4-5-20251001

# 발송 모드: review_first | auto_send
SEND_MODE=review_first
